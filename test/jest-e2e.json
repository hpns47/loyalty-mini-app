{
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "..",
    "testEnvironment": "node",
    "testRegex": "./test/.+\\.e2e-spec\\.ts$",
    "transform": {
        "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "tsconfig.e2e.json" }]
    },
    "moduleNameMapper": {
        "^src/(.*)$": "<rootDir>/src/$1"
    }
}
