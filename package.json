{
    "name": "loyalty-mini-app-backend",
    "version": "0.0.2",
    "description": "Шаблон для быстрого старта проекта",
    "author": "Codewin (codewin.ru)",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "start:dev": "ts-node-dev --respawn --transpile-only --poll src/main.ts",
        "start:prod": "node dist/main",
        "dev:up": "docker compose --env-file .env.development --profile development up -d --build",
        "dev:down": "docker compose --env-file .env.development --profile development down",
        "prod:up": "docker compose --env-file .env.production --profile production up -d --build",
        "prod:down": "docker compose --env-file .env.production --profile production down",
        "dev:logs": "docker compose --env-file .env.development --profile development logs -f backend-dev",
        "prod:logs": "docker compose --env-file .env.production --profile production logs -f backend",
        "migrate:dev": "cross-env NODE_ENV=development npx sequelize-cli db:migrate --config config/config.mjs",
        "migrate:prod": "cross-env NODE_ENV=production npx sequelize-cli db:migrate --config config/config.mjs",
        "migrate:undo:dev": "cross-env NODE_ENV=development npx sequelize-cli db:migrate:undo --config config/config.mjs",
        "migrate:undo:prod": "cross-env NODE_ENV=production npx sequelize-cli db:migrate:undo --config config/config.mjs",
        "migrate:undo:all:dev": "cross-env NODE_ENV=development npx sequelize-cli db:migrate:undo:all --config config/config.mjs",
        "migrate:undo:all:prod": "cross-env NODE_ENV=production npx sequelize-cli db:migrate:undo:all --config config/config.mjs",
        "seed:dev": "cross-env NODE_ENV=development npx sequelize-cli db:seed:all --config config/config.mjs",
        "seed:prod": "cross-env NODE_ENV=production npx sequelize-cli db:seed:all --config config/config.mjs",
        "seed:undo:dev": "cross-env NODE_ENV=development npx sequelize-cli db:seed:undo:all --config config/config.mjs",
        "seed:undo:prod": "cross-env NODE_ENV=production npx sequelize-cli db:seed:undo:all --config config/config.mjs",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\" --max-warnings=0",
        "prepare": "husky",
        "prettier": "prettier --write .",
        "format:check": "prettier . --check",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "check-updates": "ncu"
    },
    "dependencies": {
        "@keyv/redis": "^4.4.0",
        "@nestjs/cache-manager": "^3.0.1",
        "@nestjs/common": "^11.1.16",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.1.16",
        "@nestjs/jwt": "^11.0.0",
        "@nestjs/platform-express": "^11.1.16",
        "@nestjs/sequelize": "^11.0.0",
        "@nestjs/swagger": "^11.2.0",
        "@nestjs/throttler": "^6.5.0",
        "bcryptjs": "^2.4.3",
        "cache-manager": "^7.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.2",
        "cross-env": "^7.0.3",
        "helmet": "^8.1.0",
        "ioredis": "^5.6.1",
        "joi": "^17.13.3",
        "jsonwebtoken": "^9.0.2",
        "nestjs-i18n": "^10.5.1",
        "pg": "^8.16.0",
        "pg-hstore": "^2.3.4",
        "qrcode": "^1.5.4",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "sequelize": "^6.37.7",
        "sequelize-typescript": "^2.1.6"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.1",
        "@eslint/js": "^9.29.0",
        "@nestjs/cli": "^11.0.16",
        "@nestjs/schematics": "^11.0.9",
        "@nestjs/testing": "^11.1.3",
        "@types/bcryptjs": "^2.4.6",
        "@types/express": "^5.0.3",
        "@types/joi": "^17.2.3",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^24.0.1",
        "@types/qrcode": "^1.5.5",
        "eslint": "^9.29.0",
        "eslint-config-prettier": "^10.1.5",
        "eslint-plugin-prettier": "^5.4.1",
        "globals": "^16.2.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.2",
        "npm-check-updates": "^18.0.1",
        "prettier": "^3.5.3",
        "sequelize-cli": "^6.6.3",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.34.0"
    },
    "lint-staged": {
        "**/*.{js,ts,json,md}": [
            "prettier --write"
        ]
    }
}
